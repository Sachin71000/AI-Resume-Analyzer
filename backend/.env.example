# AI Resume Analyzer — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

FLASK_APP=run.py
FLASK_ENV=production

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Database — use PostgreSQL in production (Render provides this)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# For local dev, leave unset to use SQLite:
# DATABASE_URL=sqlite:///../instance/app.db

# Gemini API — get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.vercel.app

# Logging
LOG_LEVEL=INFO
